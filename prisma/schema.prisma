// ReservoExpress - Prisma schema
// Appointment booking app with dual roles (client / provider)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- User ----
// role: CLIENT or PROVIDER. Single app, dual experience.
model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         String         @default("CLIENT") // CLIENT | PROVIDER
  phone        String?
  avatarColor  String         @default("#f59e0b") // used for avatar fallback
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  provider     Provider?
  appointments Appointment[]  @relation("ClientAppointments")
  reviews      Review[]
  notifications Notification[]
}

// ---- Provider ----
// A user with role=PROVIDER has one provider profile.
model Provider {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName  String
  category      String   // e.g. "coiffeur", "medecin", "garagiste", "esthetique", "sport"
  description   String
  address       String
  city          String
  lat           Float
  lng           Float
  photos        String   @default("[]") // JSON array of image URLs
  openingHours  String   @default("{}") // JSON: { "1": {open:"09:00", close:"18:00"}, ... } weekday 0=Sun..6=Sat
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  services        Service[]
  appointments    Appointment[]
  unavailabilities Unavailability[]
  reviews         Review[]
}

// ---- Service ----
// A provider can offer multiple services with different durations.
model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  durationMin Int      // duration in minutes
  price       Float    // price in EUR
  createdAt   DateTime @default(now())

  appointments Appointment[]
}

// ---- Appointment ----
// All times stored in UTC. Display converted to local timezone client-side.
// Status flow: CONFIRMED -> COMPLETED or CANCELLED
model Appointment {
  id          String   @id @default(cuid())
  clientId    String
  client      User     @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  startTime   DateTime // UTC
  endTime     DateTime // UTC
  status      String   @default("CONFIRMED") // CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
  cancelReason String?
  depositPaid Float    @default(0) // simulated online deposit
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review      Review?

  @@index([providerId, startTime])
  @@index([clientId, startTime])
}

// ---- Unavailability ----
// Provider-declared blocks: vacations, breaks, etc.
model Unavailability {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  startDate   DateTime // UTC inclusive
  endDate     DateTime // UTC exclusive
  reason      String   @default("Indisponible")
  createdAt   DateTime @default(now())

  @@index([providerId, startDate])
}

// ---- Review ----
// Submitted by client after a COMPLETED appointment.
model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clientId      String
  client        User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  providerId    String
  provider      Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  rating        Int         // 1..5
  comment       String      @default("")
  createdAt     DateTime    @default(now())

  @@index([providerId])
}

// ---- Notification ----
// In-app notifications: confirmations, reminders, cancellations.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // BOOKING_CONFIRMED | REMINDER_D1 | BOOKING_CANCELLED | NEW_REVIEW | NEW_BOOKING
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
